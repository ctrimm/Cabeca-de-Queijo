---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import { seasons } from '../../data/seasons';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const playoffBadge = (result: string, roundPt?: string, opponent?: string, score?: string) => {
  if (result === 'no-playoffs')    return { text: 'Sem Playoffs Formais',           color: 'bg-slate-100 text-slate-400' };
  if (result === 'missed')         return { text: t('seasons.missedPlayoffs'),        color: 'bg-slate-100 text-slate-500' };
  if (result === 'won-super-bowl') return { text: '🏆 Campeões do Super Bowl',       color: 'bg-yellow-100 text-yellow-800' };
  if (result === 'won-championship') return { text: '🏆 Campeões da NFL',            color: 'bg-yellow-100 text-yellow-800' };
  const roundStr = roundPt ? `${t('seasons.lostIn')} ${roundPt}` : t('seasons.lostIn');
  const vsStr = opponent ? ` ${t('seasons.vs')} ${opponent}` : '';
  const scoreStr = score ? ` (${score})` : '';
  return { text: `${roundStr}${vsStr}${scoreStr}`, color: 'bg-red-50 text-red-700' };
};

// Agrupar anos por década
const decades = Array.from(
  new Set(seasons.map(s => Math.floor(s.year / 10) * 10))
).sort((a, b) => b - a);
---

<Layout
  seoTitle="Histórico de Temporadas — Cabeça de Queijo | Packers desde 1919"
  seoDescription="Histórico completo das temporadas do Green Bay Packers de 1919 até hoje — recordes, técnicos, campeonatos e momentos marcantes de cada era."
  seoOpenGraph={{
    basic: {
      title: "Histórico de Temporadas — Cabeça de Queijo",
      type: "website",
      image: "https://cabecadequeijo.com/og/seasons-pt.png",
      url: "https://cabecadequeijo.com/pt-BR/seasons/",
    },
    image: { alt: "Histórico de Temporadas — Cabeça de Queijo Torcida dos Packers no Brasil" },
  }}
>
  <Container>
    <div class="mt-14 mb-20">
      <p class="text-blue-500 uppercase tracking-wider text-sm font-semibold mb-2">História dos Packers</p>
      <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">{t('seasons.title')}</h1>
      <p class="text-lg text-slate-600 mt-4 max-w-2xl">{t('seasons.description')}</p>

      <!-- Legenda das eras -->
      <div class="mt-6 flex flex-wrap gap-3 text-sm">
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-full bg-yellow-300"></span> Campeonato / Super Bowl</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-full bg-red-200"></span> Eliminado nos Playoffs</span>
        <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-full bg-slate-200"></span> Fora dos Playoffs</span>
      </div>

      <!-- Navegação por década -->
      <div class="mt-6 flex flex-wrap gap-2">
        {decades.map(d => (
          <a
            href={`#decada-${d}`}
            class="px-3 py-1.5 text-sm font-semibold rounded-lg bg-green-800 text-white hover:bg-yellow-400 hover:text-green-900 transition"
          >
            {d}s
          </a>
        ))}
      </div>

      <!-- Cards de temporada agrupados por década -->
      {decades.map(decade => {
        const decadeSeasons = seasons.filter(s => Math.floor(s.year / 10) * 10 === decade);
        return (
          <div id={`decada-${decade}`} class="mt-12 scroll-mt-24">
            <h2 class="text-2xl font-bold text-slate-700 mb-4 pb-2 border-b border-slate-200">
              {decade}s
            </h2>
            <div class="space-y-4">
              {decadeSeasons.map(s => {
                const badge = playoffBadge(s.playoff.result, s.playoff.roundPt, s.playoff.opponent, s.playoff.score);
                const isChamp = s.playoff.result === 'won-super-bowl' || s.playoff.result === 'won-championship';
                return (
                  <div id={`temporada-${s.year}`} class={`border rounded-2xl overflow-hidden scroll-mt-24 ${isChamp ? 'border-yellow-400 border-2' : 'border-slate-200'}`}>
                    <div class={`text-white px-6 py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 ${isChamp ? 'bg-yellow-700' : 'bg-green-800'}`}>
                      <div class="flex items-center gap-4">
                        <span class="text-3xl font-bold text-yellow-400">{s.year}</span>
                        <span class="text-2xl font-semibold">{s.record}</span>
                      </div>
                      <span class={`text-sm font-semibold px-3 py-1.5 rounded-full self-start sm:self-auto ${badge.color}`}>
                        {badge.text}
                      </span>
                    </div>
                    <div class="px-6 py-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-1">{t('seasons.coach')}</p>
                        <p class="font-medium text-slate-800">{s.coach}</p>
                      </div>
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-1">{t('seasons.qb')}</p>
                        <p class="font-medium text-slate-800">{s.qb}</p>
                      </div>
                      <div>
                        <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-1">{t('seasons.division')}</p>
                        <p class="font-medium text-slate-800">{s.divisionFinish}</p>
                      </div>
                    </div>
                    <div class="px-6 pb-5 border-t border-slate-100 pt-4">
                      <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-2">{t('seasons.highlights')}</p>
                      <ul class="space-y-1">
                        {s.notablePt.map(note => (
                          <li class="text-slate-600 text-sm flex gap-2">
                            <span class="text-yellow-500 shrink-0">›</span>
                            <span>{note}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </Container>
</Layout>
