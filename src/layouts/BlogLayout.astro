---
import Container from "@components/container.astro";
import { getFormattedDate } from "@utils/all";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout
  seoTitle={frontmatter.title}
  seoDescription={frontmatter.description}
  seoOpenGraph={{
    basic: {
      title: frontmatter.title,
      type: "article",
      image: frontmatter.image,
      url: `https://cabecadequeijo.com/blog/${frontmatter.slug}/`,
    },
    image: {
      alt: frontmatter.title,
    },
    article: {
      publishedTime: frontmatter.publishDate,
      authors: [frontmatter.author],
      tags: frontmatter.tags,
    },
  }}
>
  <Container>
    <div class="mx-auto max-w-[735px] mt-14">
      <span class="text-packers-gold-600 uppercase tracking-wider text-sm font-semibold">
        {frontmatter.category}
      </span>
      <h1
        class="text-4xl lg:text-5xl font-bold lg:tracking-tight mt-1 lg:leading-tight text-base-content">
        {frontmatter.title}
      </h1>
      <div class="flex gap-2 mt-3 items-center flex-wrap md:flex-nowrap">
        <span class="text-base-content/50">
          {frontmatter.author}
        </span>
        <span class="text-base-content/50">•</span>
        <time class="text-base-content/50" datetime={frontmatter.publishDate}>
          {getFormattedDate(frontmatter.publishDate)}
        </time>
        <span class="text-base-content/50 hidden md:block">•</span>
        <div class="w-full md:w-auto flex flex-wrap gap-3">
          {
            frontmatter.tags.map((tag) => (
              <span class="text-sm text-packers-green-600 bg-packers-green-50 px-2 py-0.5 rounded-full">#{tag}</span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mx-auto prose prose-lg mt-6">
      <slot />
    </div>
    <div class="text-center mt-8">
      <a
        href="/blog/"
        class="bg-packers-green-50 text-packers-green-900 px-5 py-3 rounded-lg hover:bg-packers-green-100 transition font-medium"
        >← Back to Blog</a
      >
    </div>
  </Container>
</Layout>
