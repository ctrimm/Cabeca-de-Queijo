---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const styles = {
  outline: "bg-white border-2 border-packers-green-900 hover:bg-packers-green-50 text-packers-green-900",
  primary: "bg-packers-green-900 text-white hover:bg-packers-green-800 border-2 border-transparent",
  inverted: "bg-white text-packers-green-900 border-2 border-transparent",
  muted: "bg-base-200 hover:bg-base-300 border-2 border-transparent",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "rounded-lg text-center transition font-medium focus-visible:ring-2 ring-offset-2 ring-packers-green-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
