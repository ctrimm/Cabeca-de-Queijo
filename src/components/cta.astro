---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div
  class="bg-primary p-8 md:px-20 md:py-20 mt-16 mx-auto max-w-5xl rounded-2xl flex flex-col items-center text-center shadow-xl">
  <h2 class="text-packers-gold-500 text-4xl md:text-6xl tracking-tight font-extrabold">
    {t("cta.goPackGo")}
  </h2>
  <p class="text-packers-green-200 mt-4 text-lg md:text-xl">
    {t("cta.subtext")}
  </p>
  <div class="mt-8 flex flex-wrap gap-3 justify-center">
    <a href={t("cta.button1Link")} role="button" class="btn btn-secondary font-bold hover:brightness-110">{t("cta.button1Text")}</a>
    <a href={t("cta.button2Link")} role="button" class="btn btn-outline border-packers-gold-500 text-packers-gold-500 hover:bg-packers-gold-500 hover:text-packers-green-900 hover:border-packers-gold-500 font-bold">{t("cta.button2Text")}</a>
  </div>
</div>
