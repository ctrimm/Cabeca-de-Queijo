---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Chapter {
  city: string;
  members: string;
  chapterMeetingPlace: string;
  chapterMeetingAddressLink: string;
  status: "Active" | "Coming Soon" | "Em breve" | "Inactive";
  slug: string;
}

const chapterList: Chapter[] = [
  {
    slug: "sao-paulo",
    city: "São Paulo",
    members: "12",
    chapterMeetingPlace: "Watch Parties",
    chapterMeetingAddressLink: lang === 'pt-BR' ? "/pt-BR/chapters/sao-paulo/" : "/chapters/sao-paulo/",
    status: "Active"
  },
  {
    slug: "santos",
    city: "Santos",
    members: "22",
    chapterMeetingPlace: "Lambeau Field Northeast",
    chapterMeetingAddressLink: lang === 'pt-BR' ? "/pt-BR/chapters/santos/" : "/chapters/santos/",
    status: lang === 'pt-BR' ? "Em breve" : "Coming Soon"
  },
  {
    slug: "salvador",
    city: "Salvador",
    members: "22",
    chapterMeetingPlace: lang === 'pt-BR' ? "Campo Lambeau Nordeste" : "Lambeau Field Northeast",
    chapterMeetingAddressLink: lang === 'pt-BR' ? "/pt-BR/chapters/salvador/" : "/chapters/salvador/",
    status: lang === 'pt-BR' ? "Em breve" : "Coming Soon"
  },
  {
    slug: "amazonia",
    city: "Amazônia",
    members: "~10",
    chapterMeetingPlace: lang === 'pt-BR' ? "Campo Lambeau Amazônia" : "Lambeau Field Amazonia",
    chapterMeetingAddressLink: lang === 'pt-BR' ? "/pt-BR/chapters/amazonia/" : "/chapters/amazonia/",
    status: lang === 'pt-BR' ? "Em breve" : "Coming Soon"
  },
  {
    slug: "brasilia",
    city: "Brasília",
    members: "~10",
    chapterMeetingPlace: lang === 'pt-BR' ? "Campo Lambeau Amazônia" : "Lambeau Field Amazonia",
    chapterMeetingAddressLink: lang === 'pt-BR' ? "/pt-BR/chapters/brasilia/" : "/chapters/brasilia/",
    status: lang === 'pt-BR' ? "Em breve" : "Coming Soon"
  }
];
---

<div class="pt-8 md:pt-16 pb-2 md:pb-6" id="chapters">
  <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight text-base-content">
    {t("chapters.chapterListTitle")}
  </h1>
  <div class="grid md:grid-cols-4 gap-4 max-h-100 text-lg mt-6">
    {
      chapterList.map((chapter, index) => {
        if (chapter.status === "Coming Soon" || chapter.status === "Em breve") {
          return (
            <div class="relative border border-base-300 rounded-2xl p-4 min-h-56 overflow-hidden">
              <div class="absolute inset-0 bg-packers-green-900 bg-opacity-80 flex flex-col items-center justify-center rounded-2xl backdrop-blur-sm">
                <span class="font-extrabold text-white text-3xl pb-2">{chapter.city}</span>
                <span class="font-bold text-packers-gold-500 text-xl pb-3">{t("chapters.chapterComingSoon")}</span>
                <a href={lang === 'pt-BR' ? "/pt-BR/join/" : "/join/"} class="btn btn-secondary btn-sm font-bold">
                  {t("chapters.getNotified")}
                </a>
              </div>
            </div>
          )
        } else {
          return (
            <div class="relative border border-packers-green-200 rounded-2xl p-4 hover:shadow-lg transition-shadow min-h-56 bg-white">
              <h3 class="text-3xl font-extrabold tracking-tight text-center text-packers-green-900">
                {chapter.city}
              </h3>
              <div class="w-12 h-0.5 bg-packers-gold-500 mx-auto my-3 rounded-full"></div>
              <p class="text-lg font-semibold mt-2 text-base-content/80">
                👪 {chapter.members} {t("chapters.members")}
              </p>
              <p class="text-lg font-semibold mt-2 text-base-content/80">
                <a href={`${chapter.chapterMeetingAddressLink}`} class="hover:text-packers-green-700">🗺️ {chapter.chapterMeetingPlace}</a>
              </p>
              {
                (chapter.status === "Active") && (
                <a href={`${lang === 'pt-BR' ? "/pt-BR" : ""}/chapters/${chapter.slug}/`} class="btn btn-primary text-lg mt-3 w-full font-bold">
                  {t("chapters.learnMore")}
                </a>
              )}
            </div>
          )
        }
      })
    }
  </div>
</div>
