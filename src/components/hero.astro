---
import { Image } from "astro:assets";
import mainLogoImage from "assets/main.png";
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<main class="grid lg:grid-cols-2 place-items-center pt-8 md:pt-20 pb-4 md:pb-10">
  <div class="py-6 order-last sm:block">
    <Image
      src={mainLogoImage}
      alt={t('hero.altTag')}
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <div class="text-3xl lg:text-5xl xl:text-6xl lg:tracking-tight xl:tracking-tighter text-base-content">
      <span>{t('hero.title.part1')}</span>
      <span class="font-italic font-skinny">{t('hero.title.part2')}</span>
      <span>{t('hero.title.part3')}</span>
      <span class="block text-5xl lg:text-5xl xl:text-6xl font-bold lg:tracking-tight xl:tracking-tighter bg-clip-text text-transparent bg-gradient-to-r from-packers-green-900 to-packers-green-600">{t('hero.title.part4')}</span>
      <span class="block">{t('hero.title.part5')}</span>
    </div>
    <p class="text-lg mt-6 text-base-content/70 max-w-xl leading-relaxed">
      {t('hero.subtitle')}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={t('hero.button1.link')} role="button" class="btn btn-secondary font-bold shadow-md hover:shadow-lg hover:brightness-110">{t('hero.button1.text')}</a>
      <a href={t('hero.button2.link')} role="button" class="btn btn-primary font-bold shadow-md hover:shadow-lg">{t('hero.button2.text')}</a>
    </div>
  </div>
</main>
